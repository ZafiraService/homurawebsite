{
  "name": "homura-community",
  "version": "1.0.0",
  "description": "Homura Discord Community Website with Admin Panel",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:setup": "npx prisma migrate dev --name init",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio"
  },
  "keywords": [
    "discord",
    "community",
    "homura",
    "admin"
  ],
  "author": "Homura Team",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.1.0",
    "body-parser": "^1.20.2"
  },
  "devDependencies": {
    "prisma": "^5.0.0",
    "nodemon": "^3.0.1"
  }
}
